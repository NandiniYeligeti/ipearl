# Razorpay Configuration
# Get these from your Razorpay dashboard: https://dashboard.razorpay.com/

# Your Razorpay API Key ID
RAZORPAY_KEY_ID=your_key_id_here

# Your Razorpay API Secret Key
RAZORPAY_KEY_SECRET=your_key_secret_here

# Public Razorpay Key (visible to frontend)
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_key_id_here
